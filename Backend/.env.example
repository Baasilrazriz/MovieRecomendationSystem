# Copy this file to .env and update the values
# All values below are used throughout the application

# 🔐 JWT Secret Key - CHANGE THIS IN PRODUCTION!
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Example: A9kF_r7xJ2m-QpLwZ8sT1vU4nD5cB6eH9wG_zYxJ3m
SECRET_KEY="your-secret-key-change-in-production"

# 🐛 Debug Mode (True for development, False for production)
# Used by Flask app for error reporting and auto-reload
DEBUG="False"

# 🌍 Environment Type (development, staging, production)
# Affects logging verbosity and error reporting
ENVIRONMENT="production"

# 🎬 Optional: OMDb API Key for enhanced poster/metadata
# Get free key at: https://www.omdbapi.com/apikey.aspx
# Leave blank to use default data
OMDB_API_KEY=""
