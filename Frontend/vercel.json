{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "env": {
    "VITE_API_URL": {
      "required": true
    },
    "VITE_ENVIRONMENT": {
      "required": false
    },
    "VITE_DEBUG": {
      "required": false
    },
    "VITE_API_TIMEOUT": {
      "required": false
    }
  }
}
